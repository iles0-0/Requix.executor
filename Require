    TweenService:Create(NotifFrame, TweenInfo.new(0.2), {BackgroundTransparency = BackgroundTransparency}):Play()
    NotifFrame:TweenPosition(UDim2.new(1, -200, 1, -64), "Out", "Back", 0.3)
    
    task.wait(Duration)
    
    NotifFrame:TweenPosition(UDim2.new(1, -200, 1, -40), "In", "Quad", 0.25)
