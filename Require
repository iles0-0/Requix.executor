local function RefreshHistory()
    for _, c in ipairs(HistList:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
    for _, entry in ipairs(ScriptHistory) do
        local eb = Instance.new("TextButton")
        eb.Size = UDim2.new(1,0,0,26)
        eb.BackgroundTransparency = 1
        eb.Font = Enum.Font.Gotham
        eb.Text = entry.Name or ("Script #" .. entry.ID)
        eb.TextSize = 11
        eb.TextColor3 = Colors.SubText
        eb.TextXAlignment = Enum.TextXAlignment.Left
        eb.ZIndex = 123
        eb.Parent = HistList
        Instance.new("UIPadding",eb).PaddingLeft = UDim.new(0,8)
        eb.Activated:Connect(function()
            TextBox.Text = tostring(entry.ID)
            HistDrop.Visible = false
            HistoryOpen = false
        end)
    end
    HistList.CanvasSize = UDim2.new(0,0,0,#ScriptHistory * 28)
    local cnt = math.min(#ScriptHistory, 6)
    HistDrop.Size = UDim2.new(0,200,0,cnt * 28 + 8)
end

