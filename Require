local function Obfuscate(idOrCode)
    local code = ""
    if type(idOrCode) == "number" then
        -- Шифруем require(ID)
        code = "local _r = string.reverse('eriuqer'); getfenv()[_r](" .. idOrCode .. ")"
    else
