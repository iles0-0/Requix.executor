local function TriggerRun()
    local input = TextBox.Text:gsub("%s+","")
    local id = tonumber(input:match("%d+"))
    
    if not id then 
        Requiex:Log("ID not found in input", "ERROR") 
        return 
    end

    Requiex:Log("Attempting Execute #"..id, Colors.AccentYellow)

    if Requiex._execBackdoor then
