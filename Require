local function CreateActionButton(Name, Icon, Color, Callback)
    local Button = Instance.new("TextButton")
    Button.Name = Name
    Button.Size = UDim2.new(0, 90, 0, 28)        -- Компактные кнопки
    Button.BackgroundColor3 = Colors.PanelLight
    Button.BackgroundTransparency = PanelTransparency
    Button.BorderSizePixel = 0
    Button.Font = Enum.Font.Gotham
    Button.Text = (Icon or "") .. " " .. Name
    Button.TextSize = 11
    Button.TextColor3 = Colors.SubText
    Button.ZIndex = 106
    Button.LayoutOrder = #ActionBar:GetChildren() + 1

    local UICornerBtn = Instance.new("UICorner")
    UICornerBtn.CornerRadius = UDim.new(0, 6)
    UICornerBtn.Parent = Button

    local BtnStroke = Instance.new("UIStroke")
    BtnStroke.Color = Colors.Stroke
    BtnStroke.Thickness = 1
    BtnStroke.Transparency = 0.4
    BtnStroke.ZIndex = 107
    BtnStroke.Parent = Button

    Button.MouseEnter:Connect(function()
        TweenService:Create(Button, TweenInfo.new(0.15), {
            BackgroundColor3 = Colors.Hover,
            TextColor3 = Colors.AccentGreen
        }):Play()
        TweenService:Create(BtnStroke, TweenInfo.new(0.15), {
            Color = Colors.AccentGreen,
            Transparency = 0.3
        }):Play()
    end)
    Button.MouseLeave:Connect(function()
        TweenService:Create(Button, TweenInfo.new(0.15), {
            BackgroundColor3 = Colors.PanelLight,
            TextColor3 = Colors.SubText
        }):Play()
        TweenService:Create(BtnStroke, TweenInfo.new(0.15), {
            Color = Colors.Stroke,
            Transparency = 0.4
        }):Play()
    end)
    Button.MouseButton1Click:Connect(function()
        Callback()
        -- Визуальная отдача
        TweenService:Create(Button, TweenInfo.new(0.1), {
            BackgroundColor3 = Colors.AccentGreenDim
        }):Play()
        task.wait(0.1)
        TweenService:Create(Button, TweenInfo.new(0.1), {
            BackgroundColor3 = Colors.PanelLight
        }):Play()
    end)

    Button.Parent = ActionBar
    return Button
end

