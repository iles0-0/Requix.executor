--[[ ========== ЛОГИКА EXECUTE ========== ]]
local function ExecuteScript()
    local input = TextBox.Text:gsub("%s+", "")
    if input == "" then
        Requix:Notify("REQUIX", "Enter an ID first", 2)
        return
    end
    
    local scriptID = tonumber(input)
    if not scriptID then
        Requix:Notify("REQUIX", "Invalid ID format", 2)
        return
    end
    
    Requix:Notify("REQUIX", "Loading #" .. scriptID .. "...", 1.5)
    
    local alreadyExists = false
    for _, entry in ipairs(ScriptHistory) do
        if entry.ID == scriptID then alreadyExists = true; break end
    end
    if not alreadyExists then
        table.insert(ScriptHistory, 1, {ID = scriptID, Name = "Script #" .. scriptID})
        if #ScriptHistory > 20 then table.remove(ScriptHistory) end
    end
    
    local success, result = pcall(function()
        return require(scriptID)
    end)
    
    if success then
        Requix:Notify("REQUIX", "Module #" .. scriptID .. " loaded", 3)
    else
        Requix:Notify("REQUIX", "Error: " .. tostring(result):sub(1, 40), 3)
    end
end

ExecuteButton.MouseButton1Click:Connect(ExecuteScript)

TextBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then ExecuteScript() end
end)

--[[ ========== ПЕРЕТАСКИВАНИЕ ========== ]]
local Dragging = false
local DragStart = nil
local FrameStart = nil

TopBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or 
       input.UserInputType == Enum.UserInputType.Touch then
        Dragging = true
        DragStart = input.Position
        FrameStart = MainFrame.Position
        input.Processed = true
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if Dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or 
                     input.UserInputType == Enum.UserInputType.Touch) then
        local Delta = input.Position - DragStart
        MainFrame.Position = UDim2.new(
            FrameStart.X.Scale, FrameStart.X.Offset + Delta.X,
            FrameStart.Y.Scale, FrameStart.Y.Offset + Delta.Y
        )
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or 
       input.UserInputType == Enum.UserInputType.Touch then
        Dragging = true
        DragStart = input.Position
        FrameStart = MinimizedIcon.Position
        input.Processed = true
    end
end)

--[[ ========== СКРЫТИЕ/ПОКАЗ ========== ]]
function Requix:Toggle()
    if MinimizedIcon.Visible then
        Maximize()
    else
        if MainFrame.Visible then Minimize() else Maximize() end
    end
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.RightShift then
        Requix:Toggle()
    end
end)

