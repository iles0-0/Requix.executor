local function CreateSmallButton(icon, label, width, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, width or 60, 0, 48)
    btn.BackgroundColor3 = Colors.DarkGray
    btn.BorderSizePixel = 0
    btn.ZIndex = 2
    btn.AutoButtonColor = false
    btn.LayoutOrder = layoutOrderCounter
    layoutOrderCounter = layoutOrderCounter + 1
    btn.Parent = ActionBar
    Instance.new("UICorner",btn).CornerRadius = UDim.new(0,9)
    local iconLabel = Instance.new("TextLabel")
    iconLabel.Size = UDim2.new(1,0,0,24)
    iconLabel.Position = UDim2.new(0,0,0,6)
    iconLabel.BackgroundTransparency = 1
    iconLabel.Font = Enum.Font.GothamBold
    iconLabel.Text = icon or ""
    iconLabel.TextSize = 18
    iconLabel.TextColor3 = Colors.SubText
    iconLabel.TextXAlignment = Enum.TextXAlignment.Center
    iconLabel.ZIndex = 3
    iconLabel.Parent = btn
    local labelText = Instance.new("TextLabel")
    labelText.Size = UDim2.new(1,0,0,14)
    labelText.Position = UDim2.new(0,0,0,30)
    labelText.BackgroundTransparency = 1
    labelText.Font = Enum.Font.Gotham
    labelText.Text = label or ""
    labelText.TextSize = 9
    labelText.TextColor3 = Colors.SubText
    labelText.TextXAlignment = Enum.TextXAlignment.Center
    labelText.ZIndex = 3
    labelText.Parent = btn
    local btnStroke = Instance.new("UIStroke")
    btnStroke.Color = Colors.Stroke
    btnStroke.Thickness = 1
    btnStroke.Transparency = 0.4
    btnStroke.Parent = btn
    SafeConnect(btn, "MouseEnter", function()
        TweenService:Create(btn,TweenInfo.new(0.2),{BackgroundColor3 = Colors.GlassHover}):Play()
        TweenService:Create(iconLabel,TweenInfo.new(0.2),{TextColor3 = Colors.AccentYellow}):Play()
        TweenService:Create(labelText,TweenInfo.new(0.2),{TextColor3 = Colors.AccentYellow}):Play()
    end)
    SafeConnect(btn, "MouseLeave", function()
        TweenService:Create(btn,TweenInfo.new(0.25),{BackgroundColor3 = Colors.DarkGray}):Play()
        TweenService:Create(iconLabel,TweenInfo.new(0.2),{TextColor3 = Colors.SubText}):Play()
        TweenService:Create(labelText,TweenInfo.new(0.2),{TextColor3 = Colors.SubText}):Play()
    end)
    SafeConnect(btn, "Activated", callback)
    return btn
end

