local currentTab = nil

function Requix:CreateTab(name, icon)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0,90,0,22)
    btn.BackgroundColor3 = Colors.PanelLight
    btn.BackgroundTransparency = PnTrans
    btn.BorderSizePixel = 0
    btn.Font = Enum.Font.Gotham
    btn.Text = (icon or "") .. " " .. name
    btn.TextSize = 10
    btn.TextColor3 = Colors.SubText
    btn.ZIndex = 104
    btn.Parent = TabFrame
    Instance.new("UICorner",btn).CornerRadius = UDim.new(0,5)

    local page = Instance.new("Frame")
    page.Size = UDim2.new(1,0,1,0)
    page.BackgroundTransparency = 1
    page.Visible = false
    page.ZIndex = 102
    page.Parent = TabContent

    local tabData = { button = btn, page = page }
    table.insert(tabs, tabData)

    btn.Activated:Connect(function() Requix:SelectTab(tabData) end)
    if #tabs == 1 then Requix:SelectTab(tabData) end
    return page
end

function Requix:SelectTab(tabData)
    for _, t in ipairs(tabs) do
        local active = (t == tabData)
        t.page.Visible = active
        if active then
            TweenService:Create(t.button, TweenInfo.new(0.2), { BackgroundColor3 = Colors.AccentGreenDim, TextColor3 = Colors.Text }):Play()
            currentTab = t
        else
            TweenService:Create(t.button, TweenInfo.new(0.2), { BackgroundColor3 = Colors.PanelLight, TextColor3 = Colors.SubText }):Play()
        end
    end
end

