        EntryButton.MouseEnter:Connect(function()
            TweenService:Create(EntryButton, TweenInfo.new(0.15), {
                TextColor3 = Colors.AccentGreen
            }):Play()
        end)
        EntryButton.MouseLeave:Connect(function()
            TweenService:Create(EntryButton, TweenInfo.new(0.15), {
                TextColor3 = Colors.SubText
            }):Play()
        end)
        EntryButton.MouseButton1Click:Connect(function()
            TextBox.Text = tostring(entry.ID)
            HistoryDropdown.Visible = false
            HistoryOpen = false
        end)
    end
    
    HistoryList.CanvasSize = UDim2.new(0, 0, 0, #ScriptHistory * 28)
    local count = math.min(#ScriptHistory, 6)
    HistoryDropdown.Size = UDim2.new(0, 200, 0, count * 28 + 8)
end

local function ToggleHistory()
    HistoryOpen = not HistoryOpen
    HistoryDropdown.Visible = HistoryOpen
    if HistoryOpen then
        HistoryDropdown.ZIndex = 120
        RefreshHistoryUI()
    end
end

