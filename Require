function Requiex:Log(message, level)
    local color = Colors.SubText
    if level == "INFO" then color = Colors.Info
    elseif level == "WARN" then color = Colors.Warn
    elseif level == "ERROR" then color = Colors.Error
    elseif level == "SUCCESS" then color = Colors.Green
    elseif typeof(level) == "Color3" then color = level end
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1,-4,0,14)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.RobotoMono
    label.Text = "[" .. os.date("%H:%M:%S") .. "] " .. message
    label.TextSize = 9
    label.TextColor3 = color
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.LayoutOrder = #LogScroll:GetChildren() + 1
    label.Parent = LogScroll
    local idMatch = message:match("#(%d+)")
    if idMatch then
        label.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                TextBox.Text = idMatch
                Requiex:Log("Copied ID: "..idMatch, "INFO")
            end
        end)
    end
    local children = LogScroll:GetChildren()
    local count = 0
    for _, c in ipairs(children) do if c:IsA("TextLabel") then count = count + 1 end end
    while count > 40 do
        local first
        for _, c in ipairs(children) do if c:IsA("TextLabel") then first = c break end end
        if first then first:Destroy() end
        count = count - 1
    end
    LogScroll.CanvasSize = UDim2.new(0,0,0,count * 15 + 2)
    LogScroll.CanvasPosition = Vector2.new(0, LogScroll.CanvasSize.Y.Offset)
end

function Requiex:SetStatus(color)
    local c = color or Colors.AccentYellow
    StatusIndicator.BackgroundColor3 = c
    LogDotLive.BackgroundColor3 = c
end

