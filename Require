    TweenService:Create(nf, TweenInfo.new(0.2), {BackgroundTransparency = BgTrans}):Play()
    nf:TweenPosition(UDim2.new(1,-200,1,-64), "Out", "Back", 0.3)
    task.wait(dur)
    nf:TweenPosition(UDim2.new(1,-200,1,-40), "In", "Quad", 0.25)
    task.wait(0.25)
    nf:Destroy()
end

