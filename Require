function Requiex:Log(message, colorOrType)
    local color
    local prefix
    if type(colorOrType) == "string" then
        if colorOrType == "INFO" or colorOrType == "info" then color = Colors.Info prefix = "[INFO]" end
        if colorOrType == "WARN" or colorOrType == "warn" then color = Colors.Warn prefix = "[WARN]" end
        if colorOrType == "ERROR" or colorOrType == "error" then color = Colors.Error prefix = "[ERROR]" end
        if not color then color = colorOrType or Colors.SubText prefix = "" end
    else
        color = colorOrType or Colors.SubText
        prefix = ""
    end
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1,-4,0,14)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.RobotoMono
    label.Text = "[" .. os.date("%H:%M:%S") .. "] " .. prefix .. " " .. message
    label.TextSize = 9
    label.TextColor3 = color
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.LayoutOrder = #LogScroll:GetChildren() + 1
    label.Parent = LogScroll

    -- Клик для копирования ID
    local idMatch = message:match("#(%d+)")
    if idMatch then
        label.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                TextBox.Text = idMatch
                Requiex:Log("Copied ID: "..idMatch, "INFO")
            end
        end)
    end

    local children = LogScroll:GetChildren()
    local count = 0
    for _, c in ipairs(children) do if c:IsA("TextLabel") then count = count + 1 end end
    while count > 40 do
        local first
        for _, c in ipairs(children) do if c:IsA("TextLabel") then first = c break end end
        if first then first:Destroy() end
        count = count - 1
    end
    LogScroll.CanvasSize = UDim2.new(0,0,0,count * 15 + 2)
    LogScroll.CanvasPosition = Vector2.new(0, LogScroll.CanvasSize.Y.Offset)
end
function Requiex:SetStatus(color) StatusIndicator.BackgroundColor3 = color or Colors.AccentYellow end

