    nf.UIStroke.Thickness = 1
    nf.UIStroke.Transparency = 0.4

    local tl = Instance.new("TextLabel")
    tl.Size = UDim2.new(1,-12,0,18)
    tl.Position = UDim2.new(0,8,0,4)
    tl.BackgroundTransparency = 1
