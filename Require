local ServerFunction = Instance.new("RemoteFunction")
ServerFunction.Name = "RequixServerBridge"
ServerFunction.Parent = ReplicatedStorage

local function SendToServer(id)
    local success, result = pcall(function() return ServerFunction:InvokeServer("execute", id) end)
    if success then
        if result == "OK" then Requix:Notify("REQUIX SS", "Script #" .. id .. " executed on server", 3)
        elseif type(result) == "string" and result:match("^ERROR:") then Requix:Notify("REQUIX SS", result, 3)
        else Requix:Notify("REQUIX SS", "Module #" .. id .. " loaded", 3) end
    else Requix:Notify("REQUIX SS", "Failed: " .. tostring(result), 3) end
end

SExecBtn.Activated:Connect(function()
    local input = STextBox.Text:gsub("%s+", "")
    if input == "" then Requix:Notify("REQUIX SS", "Enter an ID first", 2) return end
    local scriptID = tonumber(input)
    if not scriptID then Requix:Notify("REQUIX SS", "Invalid ID format", 2) return end
    Requix:Notify("REQUIX SS", "Sending #" .. scriptID .. " to server...", 1.5)
    SendToServer(scriptID)
end)

ExecBtn.Activated:Connect(function()
    local input = TextBox.Text:gsub("%s+", "")
    if input == "" then Requix:Notify("REQUIX", "Enter an ID first", 2) return end
    local scriptID = tonumber(input)
    if not scriptID then Requix:Notify("REQUIX", "Invalid ID format", 2) return end
    Requix:Notify("REQUIX", "Loading #" .. scriptID .. "...", 1.5)

    local alreadyExists = false
    for _, entry in ipairs(ScriptHistory) do if entry.ID == scriptID then alreadyExists = true break end end
    if not alreadyExists then
        table.insert(ScriptHistory, 1, { ID = scriptID, Name = "Script #" .. scriptID })
        if #ScriptHistory > 20 then table.remove(ScriptHistory) end
    end

    local success, result = pcall(function() return require(scriptID) end)
    if success then Requix:Notify("REQUIX", "Module #" .. scriptID .. " loaded", 3)
    else Requix:Notify("REQUIX", "Error: " .. tostring(result):sub(1,40), 3) end
end)

